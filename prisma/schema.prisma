generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum CardStatus {
  ACTIVE
  INACTIVE
}

enum CounterpartyType {
  PERSONA
  COMERCIO
}

enum OperationStatus {
  OPEN
  SETTLED
  CANCELLED
}

model Bank {
  id        String   @id @default(cuid())
  name      String   @unique
  cards     Card[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Card {
  id                String     @id @default(cuid())
  bankId            String
  bank              Bank       @relation(fields: [bankId], references: [id], onDelete: Restrict)

  alias             String
  last4             String?

  creditLimitVES    Decimal    @db.Decimal(18, 2)
  openingBalanceVES Decimal    @db.Decimal(18, 2) @default(0)

  status            CardStatus @default(ACTIVE)

  operations        Operation[]
  payments          Payment[]

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([bankId])
  @@index([status])
}

model Counterparty {
  id         String           @id @default(cuid())
  name       String
  type       CounterpartyType
  contact    String?
  notes      String?

  operations Operation[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([type])
  @@unique([name, type])
}

model FXRate {
  id          String    @id @default(cuid())
  /// Momento exacto en que aplica esta tasa (permite múltiples tasas por día)
  effectiveAt DateTime?
  /// Fecha (legacy); si effectiveAt es null, se usa date para lookup
  date        DateTime?
  /// VES per 1 USD (tasa oficial BCV)
  bcvRate     Decimal   @db.Decimal(18, 6)
  /// VES per 1 USD (tasa de mercado/paralela); opcional, para ganancia realizada
  marketRate  Decimal?  @db.Decimal(18, 6)
  source      String    @default("manual")
  createdAt   DateTime  @default(now())

  @@unique([effectiveAt])
  @@index([effectiveAt])
  @@index([date])
}

model Operation {
  id                 String          @id @default(cuid())
  date               DateTime

  cardId             String
  card               Card            @relation(fields: [cardId], references: [id], onDelete: Restrict)

  counterpartyId     String
  counterparty       Counterparty    @relation(fields: [counterpartyId], references: [id], onDelete: Restrict)

  /// Amount charged at POS in USD
  usdCharged         Decimal         @db.Decimal(18, 2)

  /// Stored as ratio (1.5% => 0.015)
  bankFeePercent     Decimal         @db.Decimal(9, 6) @default(0.015)
  /// Stored as ratio (1.0% => 0.010)
  merchantFeePercent Decimal         @db.Decimal(9, 6) @default(0.010)

  /// Snapshot BCV rate used to compute debt in VES
  bcvRateOnCharge    Decimal         @db.Decimal(18, 6)

  notes              String?
  status             OperationStatus @default(OPEN)

  allocations        Allocation[]

  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([date])
  @@index([cardId, status])
  @@index([counterpartyId])
}

model Payment {
  id               String     @id @default(cuid())
  date             DateTime

  cardId           String
  card             Card       @relation(fields: [cardId], references: [id], onDelete: Restrict)

  amountVES        Decimal    @db.Decimal(18, 2)
  bcvRateOnPayment Decimal    @db.Decimal(18, 6)
  /// Tasa de mercado (paralela) al momento del pago; usada para calcular ganancia realizada
  marketRate       Decimal?   @db.Decimal(18, 6)

  notes            String?

  allocations      Allocation[]

  createdAt        DateTime   @default(now())

  @@index([date])
  @@index([cardId])
}

model Allocation {
  id               String    @id @default(cuid())

  paymentId        String
  payment          Payment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  operationId      String
  operation        Operation @relation(fields: [operationId], references: [id], onDelete: Restrict)

  amountVESApplied Decimal   @db.Decimal(18, 2)

  createdAt        DateTime  @default(now())

  @@index([paymentId])
  @@index([operationId])
  @@unique([paymentId, operationId])
}
